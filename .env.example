# App
APP_NAME=CSE Pulse LinkedIn Monitor
ENV=development
MOCK_MODE=true
LOG_LEVEL=INFO

# Storage
DATA_FILE=data/activities.json

# AI provider (placeholder for future real model integration)
AI_PROVIDER=mock
AI_MODEL=gpt-4o-mini

# Google Sheets (optional scaffold)
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_WORKSHEET=Sheet1

# Gmail (future integration scaffold)
GMAIL_QUERY=from:linkedin.com
GMAIL_MAX_RESULTS=25

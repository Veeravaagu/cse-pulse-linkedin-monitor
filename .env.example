# Application
APP_NAME=CSE Pulse
ENV=development
MOCK_MODE=true
LOG_LEVEL=INFO

# Storage
# Local JSON persistence for development and demos.
DATA_FILE=data/activities.json
# Cursor for narrowing successful Gmail ingestion runs.
INGESTION_STATE_FILE=data/ingestion_state.json

# Enrichment
# Use "mock" for the implemented heuristic processor.
# Use "llm" only when actively developing the scaffolded LLM path.
AI_PROVIDER=mock
AI_MODEL=gpt-4o-mini

# Google Sheets sync
# Disabled by default for local development.
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_PATH=
# Backward-compatible legacy field. If set, it is treated as a file path.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_WORKSHEET=Sheet1

# Ingestion
# "mock" reads local sample payloads.
# "gmail" lists and fetches Gmail messages using the read-only Gmail API scope.
INGESTION_MODE=mock
MOCK_EMAIL_PAYLOAD_PATH=data/mock_emails/linkedin_notifications.json

# Gmail read-only ingestion
GMAIL_QUERY=from:linkedin.com
GMAIL_MAX_RESULTS=25

# Auth mode 1: service account / Workspace delegation.
# If set, this path is used before OAuth token settings.
GMAIL_CREDENTIALS_PATH=

# Auth mode 2: local OAuth user token.
# Generate this token outside app runtime; ingestion will not launch a browser.
GMAIL_OAUTH_CLIENT_SECRET_PATH=
GMAIL_TOKEN_PATH=
